{
  "name": "everything-claude-code-mobile",
  "version": "1.1.1",
  "description": "Complete Claude Code plugin for Android, iOS, and KMP mobile development",
  "private": true,
  "scripts": {
    "test": "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:ci": "node --test --test-reporter=spec --test-reporter-destination=stdout tests/unit/*.test.js tests/integration/*.test.js",
    "verify": "node tests/verify.js",
    "lint:json": "node scripts/lint-json.js",
    "lint:scripts": "node --check scripts/hooks/*.js scripts/lib/*.js",
    "pretest": "npm run lint:scripts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "ahmed3elshaer",
  "license": "MIT"
}
